{
  "compilerOptions": {
    "declaration": true,
    "outDir": "./dist",
    "moduleResolution": "node",
    "target": "ES6",
    "module": "CommonJS",
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": [
    "lib/**/*",
    "./"
  ],
  "exclude": [
    "node_modules"
  ]
}